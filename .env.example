# Base URL
APP_URL=http://localhost:8000
APP_NAME="Vestidos Roma"


DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=goric_chatbot
DB_USERNAME=root
DB_PASSWORD=

# Storage
STORAGE_PATH=storage/app/products

# Groq API para visión artificial (fallback cuando Voyage no matchea)
GROQ_API_KEY=tu-api-key-aqui
GROQ_MODEL_VISION=llama-3.2-90b-vision-preview
GROQ_MODEL_CHAT=llama-3.3-70b-versatile

# Voyage AI para embeddings visuales del catálogo (voyage-multimodal-3.5)
VOYAGE_API_KEY=tu-api-key-voyage-aqui
CATALOG_VISION_ENABLED=true
CATALOG_VISION_MIN_SIMILARITY=0.72

# URL pública de la app para WhatsApp
PUBLIC_APP_URL=https://tu-ngrok-url.ngrok-free.app

# Token permanente Meta (mismo valor que meta_access_token en Supabase/roma-api). Necesario si llegan URLs lookaside.
WA_TOKEN=

# Ngrok de roma-api (puerto 3000) — debe coincidir con ROMA_API_PUBLIC_URL en roma-api/.env
ROMA_API_PUBLIC_URL=

# Pusher (para tiempo real)
BROADCAST_CONNECTION=pusher
