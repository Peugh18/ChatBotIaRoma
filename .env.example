APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# URL HTTPS pública del CRM para que Meta descargue fotos de producto (ngrok → php artisan serve :8000)
# NO uses la URL de roma-api aquí; debe ser la del Laravel CRM.
PUBLIC_APP_URL=

# Con ngrok NO uses "composer run dev" (Vite en localhost rompe CORS/mixed content).
# Usa: npm run build && composer run dev:ngrok
# y apunta ngrok al puerto 8000. Laravel confía en X-Forwarded-Proto (bootstrap/app.php).

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=roma_crm
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
BOT_ENABLE_LLM_FALLBACK=false

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_KEY}"
VITE_PUSHER_CLUSTER="${PUSHER_CLUSTER}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"

# === Integración roma-api (mismo ROMA_SYNC_TOKEN en ambos proyectos) ===
ROMA_API_ENABLED=true
# URL pública de roma-api (ngrok → npm run dev, puerto 3000)
ROMA_API_URL=https://tu-ngrok-roma-api.ngrok-free.dev
ROMA_SYNC_TOKEN=roma_sync_secret_2026
ROMA_WEBHOOK_SECRET=

# En roma-api/.env.local:
# LARAVEL_MESSAGES_URL=http://127.0.0.1:8000/api/roma/messages
# (o ngrok del CRM si Meta/webhook necesita alcanzar Laravel)

# Contrato saliente: POST {ROMA_API_URL}/api/messages
# tipos: text | image | interactive (botones/listas) | template
# Contrato entrante: POST /api/roma/messages (token X-Roma-Sync-Token)

GROQ_API_KEY=
GROQ_MODEL_CHAT=llama-3.3-70b-versatile
GROQ_MODEL_VISION=meta-llama/llama-4-scout-17b-16e-instruct

# Pusher Configuration
PUSHER_APP_ID=2156513
PUSHER_KEY=94079582c942034854e5
PUSHER_SECRET=fbb8d7b173bff61d0dd1
PUSHER_CLUSTER=us2
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# Broadcasting Configuration
BROADCAST_CONNECTION=pusher

# === Scheduler / Cron ===
# En producción, agregar esta línea al crontab del servidor:
# * * * * * cd /path-to-your-project && php artisan schedule:run >> /dev/null 2>&1
# Esto ejecutará el scheduler cada minuto para verificar recordatorios de bot
# En desarrollo (composer run dev), schedule:work se ejecuta automáticamente
